{
  "name": "ember-data-model-fragments",
  "version": "8.0.2",
  "description": "Ember Data addon to support nested JSON documents",
  "keywords": [
    "ember-addon",
    "ember",
    "ember-data",
    "ember-cli",
    "fragments"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/adopted-ember-addons/ember-data-model-fragments.git"
  },
  "license": "MIT",
  "author": "Steven Lindberg <steven@lytics.io>",
  "exports": {
    ".": {
      "types": "./declarations/index.d.ts",
      "default": "./dist/index.js"
    },
    "./addon-main.js": "./addon-main.cjs",
    "./*.css": "./dist/*.css",
    "./*": {
      "types": "./declarations/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "imports": {
    "#src/*": "./src/*"
  },
  "files": [
    "addon-main.cjs",
    "declarations",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rollup --config",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint . --no-error-on-unmatched-pattern",
    "lint:hbs:fix": "ember-template-lint . --fix --no-error-on-unmatched-pattern",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:publish": "pnpm build && publint run --level error",
    "prepack": "rollup --config",
    "start": "vite dev",
    "test": "vite build --mode=development --outDir=dist-tests && testem --file testem.cjs ci --port 0"
  },
  "dependencies": {
    "@embroider/addon-shim": "^1.8.9",
    "@embroider/macros": "^1.20.2",
    "decorator-transforms": "^2.2.2",
    "git-repo-info": "^2.1.1",
    "npm-git-info": "^1.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/runtime": "^7.29.0",
    "@ember-data/json-api": "~5.8.1",
    "@ember-data/legacy-compat": "~5.8.1",
    "@ember-data/model": "~5.8.1",
    "@ember-data/serializer": "~5.8.1",
    "@ember-data/store": "~5.8.1",
    "@ember/test-helpers": "^5.4.1",
    "@ember/test-waiters": "^4.1.1",
    "@embroider/addon-dev": "^8.1.0",
    "@embroider/compat": "^4.1.0",
    "@embroider/core": "^4.1.0",
    "@embroider/vite": "^1.1.5",
    "@eslint/js": "^9.39.4",
    "@glimmer/component": "^2.1.1",
    "@glimmer/env": "^0.1.7",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-replace": "^6.0.2",
    "@warp-drive/build-config": "~5.8.1",
    "@warp-drive/ember": "~5.8.1",
    "babel-plugin-ember-template-compilation": "^4.0.0",
    "concurrently": "^9.2.1",
    "ember-cli-deprecation-workflow": "^4.0.1",
    "ember-data": "~5.8.1",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.0.4",
    "ember-source": "^6.12.0",
    "ember-strict-application-resolver": "^0.1.0",
    "ember-template-lint": "^7.9.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-ember": "^12.7.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-qunit": "^8.2.6",
    "globals": "^16.1.0",
    "prettier": "^3.8.2",
    "prettier-plugin-ember-template-tag": "^2.1.4",
    "pretender": "^3.4.7",
    "publint": "^0.3.16",
    "qunit": "^2.25.0",
    "qunit-dom": "^3.5.0",
    "release-plan": "^0.17.4",
    "rollup": "^4.22.5",
    "testem": "^3.15.1",
    "vite": "^7.1.9"
  },
  "peerDependencies": {
    "@ember-data/json-api": ">= 4.12.0",
    "@ember-data/legacy-compat": ">= 4.12.0",
    "@ember-data/model": ">= 4.12.0",
    "@ember-data/serializer": ">= 4.12.0",
    "@ember-data/store": ">= 4.12.0",
    "ember-data": ">= 4.12.0",
    "ember-source": ">= 5.0.0"
  },
  "engines": {
    "node": ">= 22.19"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js"
    ]
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "version": 2,
    "type": "addon",
    "main": "addon-main.cjs",
    "app-js": {
      "./transforms/array.js": "./dist/_app_/transforms/array.js",
      "./transforms/fragment-array.js": "./dist/_app_/transforms/fragment-array.js",
      "./transforms/fragment.js": "./dist/_app_/transforms/fragment.js"
    }
  }
}
